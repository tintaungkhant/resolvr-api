parameters:
    noUnnecessaryCollectionCall: false
    banned_code:
        nodes:
          - type: Expr_FuncCall
            functions:
              - dd
              - debug_backtrace
              - die
              - dump
              - echo
              - eval
              - exec
              - exit
              - passthru
              - phpinfo
              - print_r
              - proc_open
              - shell_exec
              - system
              - var_dump